{
  "//": "Reference MCP config for the minecraft-java MCP server (the Fabric mod).",
  "//1": "Template only — it is NOT auto-loaded by the plugin. The connect-claude",
  "//2": "skill registers this for you; copy it to .mcp.json in a project (or use",
  "//3": "`claude mcp add`) if you'd rather do it by hand.",
  "//4": "Single-player / localhost (no auth): the server block below is all you need.",
  "//5": "Remote or authenticated server: add a headers block to the server entry —",
  "//6": "  \"headers\": { \"Authorization\": \"Bearer ${MINECRAFT_MCP_TOKEN}\" }",
  "//7": "and set MINECRAFT_MCP_TOKEN in your environment. Never commit the token.",
  "mcpServers": {
    "minecraft-java": {
      "type": "http",
      "url": "${MINECRAFT_MCP_URL:-http://localhost:8765/mcp}"
    }
  }
}
